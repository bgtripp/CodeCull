# Devin API key (required for cleanup sessions)
DEVIN_API_KEY=your_devin_api_key_here

# Devin Org ID (required for cog_ service-user keys; find in Settings > Organization)
DEVIN_ORG_ID=

# Slack Bot Token (required for DM notifications)
# Needs scopes: users:read.email, chat:write
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# GitHub PAT (required for cloning private repos and fetching PR stats)
# Fine-grained token with Contents:Read-only + Pull requests:Read-only on the target repo
GITHUB_TOKEN=

# Target repo to scan (owner/repo format for Devin sessions & git clone)
TARGET_REPO=bgtripp/LogiOps

# Optional: local path to the target repo (skips git clone if set)
# TARGET_REPO_PATH=/path/to/local/LogiOps

# Override email for Slack notifications (used when git blame returns a bot email)
# Set to the email associated with your Slack account
SLACK_NOTIFY_EMAIL=

# Dashboard URL for Slack notification links
DASHBOARD_URL=http://localhost:8000

# --- Feature flag service (Unleash or mock JSON) ---
# Set UNLEASH_URL to use a real Unleash instance; leave blank to use mock JSON
# Hosted demo: https://unleash-flag-service-ddyinhlr.fly.dev
UNLEASH_URL=
UNLEASH_ADMIN_USER=
UNLEASH_ADMIN_PASSWORD=
# UNLEASH_ADMIN_TOKEN=  # API token (optional, falls back to HTTP Basic Auth)
UNLEASH_PROJECT=default

# Flag owner metadata (Unleash OSS doesn't track per-flag owners)
FLAG_OWNER_EMAIL=
FLAG_OWNER_NAME=

# Path to mock LaunchDarkly data (used when UNLEASH_URL is not set)
MOCK_LD_DATA_PATH=./mock_launchdarkly.json

# Dashboard HTTP Basic Auth (optional — leave blank to disable)
DASHBOARD_USER=
DASHBOARD_PASS=

# Path to state file (default: .codecull_state.json in project root)
# For persistent volume deployment, set to /data/.codecull_state.json
CODECULL_STATE_PATH=
